--- !u!114 &1575962137
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1575962135}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\uC774 \uAC8C\uC784\uC740 \uC804\uB7B5\uC801\uC778 \uBC30\uCE58\uB97C
    \uD1B5\uD574 \uC801\uC758 \uACF5\uACA9\uC744 \uB9C9\uC544\uB0B4\uB294 \uD0C0\uC6CC
    \uB514\uD39C\uC2A4 \uC7A5\uB974\uC758 \uAC8C\uC784\uC774\uB2E4.\n\uD50C\uB808\uC774\uC5B4\uB294
    \uC2A4\uD14C\uC774\uC9C0\uB9C8\uB2E4 \uB4F1\uC7A5\uD558\uB294 \uB2E4\uC591\uD55C
    \uC801\uB4E4\uC744 \uCC98\uCE58\uD558\uAE30 \uC704\uD574 \uAD81\uC218, \uAC80\uC0AC,
    \uB9C8\uBC95\uC0AC\uC640 \uAC19\uC740 \uC720\uB2DB\uB4E4\uC744 \uC6D0\uD558\uB294
    \uC704\uCE58\uC5D0 \uBC30\uCE58\uD560 \uC218 \uC788\uB2E4.\n\n\uAC01 \uC720\uB2DB\uC740
    \uACE0\uC720\uC758 \uACF5\uACA9 \uBC29\uC2DD\uACFC \uB2A5\uB825\uC744 \uAC00\uC9C0\uACE0
    \uC788\uC5B4 \uC0C1\uD669\uC5D0 \uB9DE\uB294 \uC804\uB7B5\uC801\uC778 \uC120\uD0DD\uC774
    \uC911\uC694\uD558\uB2E4.\n\uAD81\uC218\uB294 \uC6D0\uAC70\uB9AC\uC5D0\uC11C
    \uC548\uC815\uC801\uC778 \uACF5\uACA9\uC744, \uAC80\uC0AC\uB294 \uADFC\uC811
    \uC804\uD22C\uC5D0\uC11C \uAC15\uB825\uD55C \uBC29\uC5B4\uC640 \uACF5\uACA9\uC744,
    \uB9C8\uBC95\uC0AC\uB294 \uAD11\uC5ED \uD53C\uD574\uB098 \uD2B9\uC218 \uD6A8\uACFC\uB85C
    \uC804\uD22C\uC758 \uD750\uB984\uC744 \uBC14\uAFC0 \uC218 \uC788\uB2E4.\n\n\uC801\uB4E4\uC740
    \uC6E8\uC774\uBE0C \uD615\uD0DC\uB85C \uACC4\uC18D \uB4F1\uC7A5\uD558\uBA70 \uC810\uC810
    \uB354 \uAC15\uB825\uD574\uC9C0\uAE30 \uB54C\uBB38\uC5D0, \uC790\uC6D0\uC744
    \uD6A8\uC728\uC801\uC73C\uB85C \uC0AC\uC6A9\uD558\uACE0 \uC720\uB2DB\uC744 \uC801\uC808\uD788
    \uBC30\uCE58\uD558\uB294 \uAC83\uC774 \uC2A4\uD14C\uC774\uC9C0 \uD074\uB9AC\uC5B4\uC758
    \uD575\uC2EC\uC774\uB2E4.\n\n\uBAA8\uB4E0 \uC801\uC744 \uCC98\uCE58\uD558\uAC70\uB098
    \uBAA9\uD45C\uB97C \uB2EC\uC131\uD558\uBA74 \uC2A4\uD14C\uC774\uC9C0\uB97C \uD074\uB9AC\uC5B4\uD558\uAC8C
    \uB418\uBA70, \uC810\uC810 \uB354 \uC5B4\uB824\uC6CC\uC9C0\uB294 \uB09C\uC774\uB3C4
    \uC18D\uC5D0\uC11C \uD50C\uB808\uC774\uC5B4\uC758 \uC804\uB7B5\uACFC \uD310\uB2E8\uB825\uC774
    \uC2DC\uD5D8\uB41C\uB2E4."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: dd0a5edd9a855fd489018cbd6064579e, type: 2}
